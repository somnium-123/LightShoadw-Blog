{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationStyle": "custom",
        "backgroundColor": "#F5F5F5"
      }
    },
    {
      "path": "pages/profile/index",
      "style": {
        "navigationBarTitleText": "我的",
        "navigationBarBackgroundColor": "#FFFFFF",
        "navigationBarTextStyle": "black",
        "backgroundColor": "#F5F5F5"
      }
    }
  ],
  "subPackages": [
    {
      "root": "pages/movie-detail",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "电影详情",
            "navigationBarBackgroundColor": "#FFFFFF",
            "navigationBarTextStyle": "black",
            "backgroundColor": "#F5F5F5"
          }
        }
      ]
    },
    {
      "root": "pages/search",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "搜索",
            "navigationBarBackgroundColor": "#FFFFFF",
            "navigationBarTextStyle": "black",
            "backgroundColor": "#F5F5F5"
          }
        }
      ]
    },
    {
      "root": "pages/report",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "观影报告",
            "navigationBarBackgroundColor": "#FFFFFF",
            "navigationBarTextStyle": "black",
            "backgroundColor": "#F5F5F5"
          }
        }
      ]
    }
  ],
  "globalStyle": {
    "navigationBarTitleText": "MovieBlog",
    "navigationBarBackgroundColor": "#FFFFFF",
    "navigationBarTextStyle": "black",
    "backgroundColor": "#F5F5F5",
    "backgroundColorTop": "#F5F5F5",
    "backgroundColorBottom": "#F5F5F5"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#FF6B6B",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "static/images/tab-home.png",
        "selectedIconPath": "static/images/tab-home-active.png"
      },
      {
        "pagePath": "pages/profile/index",
        "text": "我的",
        "iconPath": "static/images/tab-profile.png",
        "selectedIconPath": "static/images/tab-profile-active.png"
      }
    ]
  }
}
